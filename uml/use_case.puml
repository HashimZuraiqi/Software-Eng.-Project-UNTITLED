@startuml use_case
left to right direction
skinparam packageStyle rectangle

actor Member
actor Librarian
actor Admin
actor "Email Service" as Email
actor "Payment Gateway" as Payment

rectangle "Library Management System" {
  usecase "Search Catalog" as UC1
  usecase "Borrow Book" as UC2
  usecase "Return Book" as UC3
  usecase "Reserve Book" as UC4
  usecase "Renew Loan" as UC5
  usecase "Pay Fine" as UC6
  usecase "Manage Book Records" as UC7
  usecase "Register Member" as UC8
  usecase "Authenticate" as UC_Auth
  usecase "Send Notification" as UC_Notify
  usecase "Generate Reports" as UC9
}

' Member flows
Member --> UC1
Member --> UC2
Member --> UC3
Member --> UC4
Member --> UC5
Member --> UC6

' Librarian flows
Librarian --> UC7
Librarian --> UC8
Librarian --> UC2
Librarian --> UC3

' Admin flows
Admin --> UC9
Admin --> UC7

' Authenticate is included (mandatory) in member operations
UC2 ..> UC_Auth : <<include>>
UC3 ..> UC_Auth : <<include>>
UC4 ..> UC_Auth : <<include>>
UC5 ..> UC_Auth : <<include>>
UC6 ..> UC_Auth : <<include>>

' Authenticate is included in staff operations
UC7 ..> UC_Auth : <<include>>
UC8 ..> UC_Auth : <<include>>

' Extend: Pay Fine can occur as part of Return Book (if fines exist)
UC3 ..> UC6 : <<extend>>

' Extend: Send Notification happens after successful Borrow, Return, and Reserve
UC2 ..> UC_Notify : <<extend>>
UC3 ..> UC_Notify : <<extend>>
UC4 ..> UC_Notify : <<extend>>

' External system flows
UC_Notify --> Email
UC6 --> Payment

@enduml
